{
  "name": "@astroanywhere/cli",
  "version": "0.2.3",
  "description": "CLI for managing Astro projects, plans, tasks, and environments",
  "type": "module",
  "bin": {
    "astro-cli": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./client": {
      "import": "./dist/client.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fuse.js": "^7.1.0",
    "ink": "^6.8.0",
    "react": "^19.2.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.5",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "BSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/astro-anywhere/cli.git"
  },
  "homepage": "https://github.com/astro-anywhere/cli",
  "keywords": [
    "astro",
    "cli",
    "planning",
    "ai",
    "task-management"
  ]
}
