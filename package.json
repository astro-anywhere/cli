{
  "name": "@astroanywhere/cli",
  "version": "0.1.1",
  "description": "CLI for managing Astro projects, plans, tasks, and environments",
  "type": "module",
  "bin": {
    "astro-cli": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./client": {
      "import": "./dist/client.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "BSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/astro-anywhere/cli.git"
  },
  "homepage": "https://github.com/astro-anywhere/cli",
  "keywords": [
    "astro",
    "cli",
    "planning",
    "ai",
    "task-management"
  ]
}
